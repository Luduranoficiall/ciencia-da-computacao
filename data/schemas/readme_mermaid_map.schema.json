{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/luduranoficiall/ciencia-da-computacao/schemas/readme_mermaid_map.schema.json",
  "title": "Mermaid short id to curriculum id",
  "type": "object",
  "additionalProperties": false,
  "required": ["nodes"],
  "properties": {
    "description": {
      "type": "string"
    },
    "nodes": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    }
  }
}
