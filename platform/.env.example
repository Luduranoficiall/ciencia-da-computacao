# Copiar para .env e preencher. Nunca commitar .env.

# Obrigatorio: chave Fernet (32 bytes base64). Gerar:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONTENT_ENCRYPTION_KEY=

# Segredo JWT (min. 32 caracteres aleatorios em producao)
JWT_SECRET=

# Duracao do access JWT (minutos) e do refresh (dias), cookies HttpOnly
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=30

# SQLite (por defeito ./data/lms.db relativo ao diretorio de trabalho)
DATABASE_URL=sqlite:///./data/lms.db

# Caminho absoluto ou relativo ao CWD para o grafo do curso
CURRICULUM_JSON_PATH=../data/curriculum.json

# Textos da landing pública (JSON validado no CI)
# COURSE_PRESENTATION_JSON_PATH=../data/course_presentation.json

# true = alunos so criados por ti (POST /admin/students)
ADMIN_ONLY_REGISTRATION=true

# Opcional: criar admin no primeiro arranque
# BOOTSTRAP_ADMIN_EMAIL=admin@teudominio.pt
# BOOTSTRAP_ADMIN_PASSWORD=

# CORS (virgula). Em producao: origens do teu front / app movel WebView
CORS_ORIGINS=*

# Hardening (opcional)
REQUIRE_HTTPS=false
HSTS_MAX_AGE_SECONDS=63072000
# Hosts permitidos (virgula). Vazio = desligado. Atras de reverse proxy, use o host publico.
# TRUSTED_HOSTS=meudominio.pt,www.meudominio.pt
# Limite de tentativas de login por IP por minuto (0 = desligado)
RATE_LIMIT_AUTH_PER_MINUTE=30
